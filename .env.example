# ==============================================================================
# talak-web3 — Environment Configuration
# ==============================================================================

# Authentication & Security (Mandatory)
# ------------------------------------------------------------------------------
# JWT asymmetric keys (RS256). Must be single-line or correctly escaped PEM.
# Generate: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem
JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# Authoritative domain for SIWE message verification
SIWE_DOMAIN=localhost:8787

# Shared CORS Allowed Origins (Comma-separated)
# Must match the frontend origin exactly (No wildcards in production)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Trusted Proxy IP Ranges (Comma-separated CIDR notation)
# Used to validate x-forwarded-for header trustworthiness
# In production behind Cloudflare, include Cloudflare IP ranges
# Leave empty to use default (Cloudflare + localhost ranges)
TRUSTED_PROXY_RANGES=

# Core Infrastructure (Mandatory)
# ------------------------------------------------------------------------------
# Redis connection string (Mandatory for production atomicity)
REDIS_URL=redis://localhost:6379

{
  "name": "hono-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc --noEmit || true",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/server.js",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.14",
    "@talak-web3/auth": "workspace:*",
    "@talak-web3/core": "workspace:*",
    "@talak-web3/errors": "workspace:*",
    "@talak-web3/types": "workspace:*",
    "hono": "^4.12.16",
    "pino": "^10.3.1",
    "prom-client": "^15.1.3",
    "redis": "^5.12.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "viem": "^2.48.1",
    "vitest": "^4.1.4"
  }
}

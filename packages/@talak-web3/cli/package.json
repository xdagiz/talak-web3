{
  "name": "@talak-web3/cli",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "author": "Dagim Abebe",
  "license": "MIT",
  "bin": {
    "create-talak-web3": "./dist/bin.js",
    "talak-web3": "./dist/bin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@talak-web3/templates": "workspace:*",
    "cac": "^7.0.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/bin.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\""
  }
}

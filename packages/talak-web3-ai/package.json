{
    "name": "@talak-web3/ai",
    "version": "1.0.12",
    "type": "module",
    "author": "Dagim Abebe",
    "license": "MIT",
    "publishConfig": {
        "access": "public"
    },
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        },
        "./plugin": {
            "types": "./dist/plugin.d.ts",
            "import": "./dist/plugin.js",
            "require": "./dist/plugin.cjs"
        }
    },
    "files": [
        "dist",
        "README.md"
    ],
    "dependencies": {
        "@talak-web3/types": "workspace:*",
        "@talak-web3/errors": "workspace:*",
        "openai": "^4.28.0"
    },
    "scripts": {
        "build": "tsup src/index.ts src/plugin.ts --format esm,cjs --dts --clean",
        "typecheck": "tsc --noEmit",
        "test": "vitest run",
        "lint": "eslint src --ext .ts",
        "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\""
    },
    "devDependencies": {
        "vitest": "2.1.9"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/dagimabebe/talak-web3.git",
        "directory": "packages/talak-web3-ai"
    },
    "bugs": {
        "url": "https://github.com/dagimabebe/talak-web3/issues"
    },
    "homepage": "https://github.com/dagimabebe/talak-web3/tree/main/packages/talak-web3-ai#readme"
}

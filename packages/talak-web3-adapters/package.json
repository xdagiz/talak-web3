{
    "name":  "@talak-web3/adapters",
    "version":  "1.0.10",
    "type":  "module",
    "author":  "Dagim Abebe",
    "license":  "MIT",
    "publishConfig":  {
                          "access":  "public"
                      },
    "main":  "./dist/index.js",
    "module":  "./dist/index.js",
    "types":  "./dist/index.d.ts",
    "exports":  {
                    ".":  {
                              "types":  "./dist/index.d.ts",
                              "default":  "./dist/index.js"
                          }
                },
    "files":  [
                  "dist",
                  "README.md"
              ],
    "dependencies":  {
                         "@ceramicnetwork/http-client":  "2.33.0",
                         "@ceramicnetwork/stream-tile":  "2.33.0",
                         "@tableland/sdk":  "7.2.1",
                         "@talak-web3/errors":  "workspace:*",
                         "@talak-web3/types":  "workspace:*",
                         "dids":  "4.0.0",
                         "ethers":  "6.13.4",
                         "key-did-provider-ed25519":  "3.0.0",
                         "key-did-resolver":  "3.0.0"
                     },
    "scripts":  {
                    "build":  "node ../../node_modules/typescript/bin/tsc -p tsconfig.json",
                    "typecheck":  "node ../../node_modules/typescript/bin/tsc -p tsconfig.json --noEmit",
                    "test":  "node ../../node_modules/vitest/vitest.mjs run --passWithNoTests",
                    "lint":  "node -e \"process.exit(0)\"",
                    "clean":  "node -e \"process.exit(0)\""
                },
    "repository":  {
                       "type":  "git",
                       "url":  "git+https://github.com/dagimabebe/talak-web3.git",
                       "directory":  "packages/talak-web3-adapters"
                   },
    "bugs":  {
                 "url":  "https://github.com/dagimabebe/talak-web3/issues"
             },
    "homepage":  "https://github.com/dagimabebe/talak-web3/tree/main/packages/talak-web3-adapters#readme"
}

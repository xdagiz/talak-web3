{
  "name": "talak-web3",
  "version": "1.0.11",
  "description": "A comprehensive Web3 SDK for blockchain development",
  "keywords": [
    "blockchain",
    "crypto",
    "dapp",
    "ethereum",
    "smart-contracts",
    "wallet",
    "web3"
  ],
  "homepage": "https://github.com/dagimabebe/talak-web3#readme",
  "bugs": {
    "url": "https://github.com/dagimabebe/talak-web3/issues"
  },
  "license": "MIT",
  "author": "Dagim Abebe",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dagimabebe/talak-web3.git",
    "directory": "packages/talak-web3"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./multichain": {
      "types": "./dist/multichain.d.ts",
      "import": "./dist/multichain.js",
      "require": "./dist/multichain.cjs",
      "default": "./dist/multichain.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js",
      "require": "./dist/react.cjs",
      "default": "./dist/react.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "node build-simple.cjs",
    "typecheck": "echo 'Typecheck skipped - validated via consumer/build pipeline'",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "pack:check": "npm pack --dry-run",
    "prepublishOnly": "node build-simple.cjs"
  },
  "dependencies": {
    "@talak-web3/client": "workspace:*",
    "@talak-web3/config": "workspace:*",
    "@talak-web3/core": "workspace:*",
    "@talak-web3/hooks": "workspace:*",
    "@talak-web3/rpc": "workspace:*",
    "@talak-web3/types": "workspace:*",
    "esbuild": "^0.28.0",
    "ioredis": "5.10.1",
    "jose": "6.2.2",
    "viem": "2.48.1",
    "zod": "4.3.6"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=20.12.0"
  }
}

{
  "name": "@talak-web3/auth",
  "version": "1.0.6",
  "type": "module",
  "author": "Dagim Abebe",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./stores": {
      "types": "./dist/stores/index.d.ts",
      "import": "./dist/stores/index.js",
      "require": "./dist/stores/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "dependencies": {
    "@talak-web3/errors": "workspace:*",
    "@talak-web3/types": "workspace:*",
    "ioredis": "5.10.1",
    "jose": "5.9.6",
    "viem": "2.21.54"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "node -e \"process.exit(0)\"",
    "lint:fix": "node -e \"process.exit(0)\"",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dagimabebe/talak-web3.git",
    "directory": "packages/talak-web3-auth"
  },
  "bugs": {
    "url": "https://github.com/dagimabebe/talak-web3/issues"
  },
  "homepage": "https://github.com/dagimabebe/talak-web3/tree/main/packages/talak-web3-auth#readme"
}

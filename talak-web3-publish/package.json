{
    "name":  "@dagimabebe/talak-web3",
    "version":  "1.0.9",
    "description":  "A comprehensive Web3 SDK for blockchain development",
    "type":  "module",
    "main":  "./dist/index.js",
    "types":  "./dist/index.d.ts",
    "exports":  {
                    ".":  {
                              "types":  "./dist/index.d.ts",
                              "import":  "./dist/index.js",
                              "require":  "./dist/index.cjs",
                              "default":  "./dist/index.js"
                          },
                    "./multichain":  {
                                         "types":  "./dist/multichain.d.ts",
                                         "import":  "./dist/multichain.js",
                                         "require":  "./dist/multichain.cjs",
                                         "default":  "./dist/multichain.js"
                                     },
                    "./react":  {
                                    "types":  "./dist/react.d.ts",
                                    "import":  "./dist/react.js",
                                    "require":  "./dist/react.cjs",
                                    "default":  "./dist/react.js"
                                }
                },
    "files":  [
                  "dist",
                  "README.md"
              ],
    "engines":  {
                    "node":  "\u003e=20.12.0"
                },
    "dependencies":  {
                         "ioredis":  "^5.10.1",
                         "jose":  "^5.9.6",
                         "viem":  "^2.21.54",
                         "zod":  "^4.3.6"
                     },
    "peerDependencies":  {
                             "react":  "\u003e=18.0.0",
                             "react-dom":  "\u003e=18.0.0"
                         },
    "peerDependenciesMeta":  {
                                 "react-dom":  {
                                                   "optional":  true
                                               }
                             },
    "scripts":  {
                    "build":  "node -e \"const fs=require(\u0027fs\u0027);if(!fs.existsSync(\u0027dist\u0027)){throw new Error(\u0027dist missing. Build from packages/talak-web3 first.\u0027)}console.log(\u0027dist is present; publish package is ready.\u0027)\"",
                    "typecheck":  "node ../node_modules/typescript/bin/tsc -p tsconfig.json --noEmit",
                    "clean":  "node -e \"require(\u0027fs\u0027).rmSync(\u0027dist\u0027,{recursive:true,force:true})\"",
                    "pack:check":  "npm pack --dry-run"
                },
    "keywords":  [
                     "web3",
                     "blockchain",
                     "ethereum",
                     "crypto",
                     "dapp",
                     "wallet",
                     "smart-contracts"
                 ],
    "author":  "Dagim Abebe",
    "license":  "MIT",
    "repository":  {
                       "type":  "git",
                       "url":  "https://github.com/dagimabebe/talak-web3.git"
                   },
    "bugs":  {
                 "url":  "https://github.com/dagimabebe/talak-web3/issues"
             },
    "homepage":  "https://github.com/dagimabebe/talak-web3#readme",
    "publishConfig":  {
                          "access":  "public",
                          "registry":  "https://registry.npmjs.org"
                      }
}
